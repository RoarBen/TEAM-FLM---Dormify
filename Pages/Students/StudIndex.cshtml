@page
@model DormManagementSystem.Pages.Students.IndexModel
@{
    ViewData["Title"] = "Student Records";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center my-4">
        <h2 class="fw-bold"><i class="bi bi-people-fill text-warning me-2"></i>Student Records</h2>
        
        <a asp-page="./Create" class="btn btn-warning fw-bold px-4 shadow-sm" style="border-radius: 20px;">
            Add Student
        </a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        </div>
    }

    <div class="card border-0 shadow-sm" style="border-radius: 10px;">
        <div class="table-responsive">
            <table class="table align-middle mb-0 text-uppercase">
                <thead class="bg-light small fw-bold">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.StudentList)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">@item.StudentID</td>
                            <td>@item.FullName</td>
                            <td class="text-muted text-lowercase">@item.Email</td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    
                                    <a asp-page="./Edit" asp-route-id="@item.StudentID" class="btn btn-primary btn-sm px-3 fw-bold">
                                        <i class="bi bi-pencil-square me-1"></i> Edit
                                    </a>

                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.StudentID"
                                          onsubmit="return confirm('Delete @item.FullName?');" style="margin:0;">
                                        <button type="submit" class="btn btn-danger btn-sm px-3 fw-bold text-white">
                                            <i class="bi bi-trash-fill me-1"></i> Delete
                                        </button>
                                    </form>

                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
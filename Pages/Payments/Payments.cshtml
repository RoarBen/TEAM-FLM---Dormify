@page
@model DormManagementSystem.Pages.Payments.IndexModel
@{
    ViewData["Title"] = "Payments";
}

<div class="d-flex justify-content-between align-items-center mb-4 px-3">
    <div>
        <h3 class="fw-bold mb-1 text-dark">
            <i class="bi bi-shield-check text-success me-2"></i>Payment Management
        </h3>
        <p class="text-muted small">GROUP FLM | Official Resident Transaction Logs</p>
    </div>
    <button class="btn btn-warning shadow-sm fw-bold px-4 rounded-pill" data-bs-toggle="modal" data-bs-target="#addPaymentModal">
        <i class="bi bi-plus-lg me-2"></i>Record New Payment
    </button>
</div>

<div class="alert alert-info border-0 shadow-sm mx-3 mb-4 d-flex align-items-center" style="border-radius: 12px;">
    <i class="bi bi-info-circle-fill fs-4 me-3"></i>
    <div>
        <strong class="d-block">Admin Reminder:</strong>
        <span class="small">Always verify the **Reference Number** for E-Wallet transactions and count **Cash** payments twice before clicking "Confirm".</span>
    </div>
</div>

<div class="card border-0 shadow-sm mx-3" style="border-radius: 15px; overflow: hidden;">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light small fw-bold text-secondary text-uppercase">
                <tr>
                    <th class="ps-4">Ref ID</th>
                    <th>Resident / Student</th>
                    <th>Method</th>
                    <th>Amount Paid</th>
                    <th>Date Processed</th>
                    <th class="text-center">Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.PaymentList)
                {
                    var reg = Model.Registrations.FirstOrDefault(r => r.RegID == item.RegID);
                    <tr>
                        <td class="ps-4 fw-bold text-secondary">#PAY-@item.PaymentID</td>
                        <td>
                            <div class="fw-bold text-dark">@(reg?.Student?.FullName ?? "Unknown Resident")</div>
                            <div class="text-muted x-small" style="font-size: 0.75rem;">Reg Ref: #@item.RegID</div>
                        </td>
                        <td>
                            @if (item.PaymentMethod == "Cash")
                            {
                                <span class="badge bg-info text-dark px-3 rounded-pill"><i class="bi bi-cash me-1"></i>Cash</span>
                            }
                            else
                            {
                                <span class="badge bg-primary px-3 rounded-pill"><i class="bi bi-phone me-1"></i>E-Wallet</span>
                            }
                        </td>
                        <td class="fw-bold text-success">₱@item.Amount.ToString("N2")</td>
                        <td class="text-muted small">@item.PaymentDate.ToString("MMM dd, yyyy")</td>
                        <td class="text-center">
                            <span class="badge bg-success-subtle text-success border border-success-subtle px-3 fw-bold">Verified</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="addPaymentModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0 pt-4 px-4">
                <h5 class="modal-title fw-bold text-dark">Process New Transaction</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post">
                <div class="modal-body p-4 pt-0">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary text-uppercase">Resident Name</label>
                        <select asp-for="NewPayment.RegID" class="form-select border-0 bg-light py-2 shadow-none" required style="border-radius: 10px;">
                            <option value="">-- Select Resident from List --</option>
                            @foreach (var reg in Model.Registrations)
                            {
                                <option value="@reg.RegID">
                                    @(reg.Student?.FullName ?? "Student") (Reg ID: @reg.RegID)
                                </option>
                            }
                        </select>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-secondary text-uppercase">Payment Mode</label>
                            <select asp-for="NewPayment.PaymentMethod" class="form-select border-0 bg-light py-2 shadow-none" style="border-radius: 10px;">
                                <option value="Cash">Cash (OTC)</option>
                                <option value="GCash/PayMaya">GCash / PayMaya</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-secondary text-uppercase">Amount (PHP)</label>
                            <input type="number" step="0.01" asp-for="NewPayment.Amount" class="form-control border-0 bg-light py-2 fw-bold text-success shadow-none" style="border-radius: 10px;" placeholder="0.00" required>
                            </div>
                        </div>

                        <div class="p-3 bg-warning-subtle border border-warning-subtle rounded-3 mb-4">
                            <div class="d-flex">
                                <i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>
                                <p class="mb-0 x-small text-dark" style="font-size: 0.8rem;">
                                    <strong>Security Notice:</strong> By clicking confirm, you certify that you have received the physical cash or verified the E-Wallet receipt from the resident.
                                </p>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-warning w-100 fw-bold py-3 shadow-sm rounded-3">
                            <i class="bi bi-check-circle-fill me-2"></i>Post & Verify Payment
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
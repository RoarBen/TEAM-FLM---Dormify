@page
@model DormManagementSystem.Pages.Dashboard.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid px-4 mt-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-1 text-dark">Dormitory Overview</h2>
        <p class="text-muted small">Real-time statistics for GROUP FLM management.</p>
    </div>
    <div class="row g-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm p-4" style="border-radius: 20px; background: #fffdf5;">
                <div class="d-flex align-items-center">
                    <div class="bg-warning p-3 rounded-4 me-3 shadow-sm"><i class="bi bi-cash-coin text-dark fs-3"></i></div>
                    <div><h6 class="text-muted mb-0 small fw-bold">REVENUE</h6><h3 class="fw-bold mb-0">₱@Model.TotalRevenue.ToString("N2")</h3></div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm p-4" style="border-radius: 20px; background: #f0f7ff;">
                <div class="d-flex align-items-center">
                    <div class="bg-primary p-3 rounded-4 me-3 text-white shadow-sm"><i class="bi bi-people-fill fs-3"></i></div>
                    <div><h6 class="text-muted mb-0 small fw-bold">RESIDENTS</h6><h3 class="fw-bold mb-0">@Model.StudentCount</h3></div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm p-4" style="border-radius: 20px; background: #f6fff9;">
                <div class="d-flex align-items-center">
                    <div class="bg-success p-3 rounded-4 me-3 text-white shadow-sm"><i class="bi bi-door-open-fill fs-3"></i></div>
                    <div><h6 class="text-muted mb-0 small fw-bold">ROOMS</h6><h3 class="fw-bold mb-0">@Model.AvailableRooms</h3></div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm p-4" style="border-radius: 20px; background: #fff5f5;">
                <div class="d-flex align-items-center">
                    <div class="bg-danger p-3 rounded-4 me-3 text-white shadow-sm"><i class="bi bi-wrench-adjustable fs-3"></i></div>
                    <div><h6 class="text-muted mb-0 small fw-bold">REPAIRS</h6><h3 class="fw-bold mb-0">@Model.PendingMaintenance</h3></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-5 g-4 pb-5">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100 p-4" style="border-radius: 20px;">
                <h6 class="fw-bold mb-4"><i class="bi bi-pie-chart-fill me-2 text-warning"></i>Occupancy</h6>
                <div style="height: 250px;"><canvas id="occupancyChart"></canvas></div>
            </div>
        </div>
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm h-100 p-4" style="border-radius: 20px;">
                <h6 class="fw-bold mb-4"><i class="bi bi-clock-history me-2 text-warning"></i>Recent Reports</h6>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light small">
                            <tr><th>ID</th><th>Room</th><th>Issue</th><th>Status</th></tr>
                        </thead>
                        <tbody class="small">
                            @foreach (var item in Model.RecentMaintenance)
                            {
                                <tr><td>#@item.MaintenanceID</td><td>Room @item.RoomID</td><td>@item.Description</td><td><span class="badge bg-warning text-dark">@item.MaintenanceStatus</span></td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('occupancyChart');
        new Chart(ctx, {
        type: 'doughnut',
        data: {
        labels: ['Available', 'Occupied'],
        datasets: [{ data: [@Model.AvailableRooms, @(10 - Model.AvailableRooms)], backgroundColor: ['#2ecc71', '#34495e'], borderWidth: 0, cutout: '70%' }]
        },
        options: { responsive: true, maintainAspectRatio: false }
        });
    </script>
}
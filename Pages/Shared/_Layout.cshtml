@{
    var currentPath = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dormify - @ViewData["Title"]</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <style>
        body { background-color: #f8f9fa; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .sidebar { min-width: 280px; max-width: 280px; min-height: 100vh; transition: all 0.3s; position: sticky; top: 0; }
        .nav-link { border-radius: 10px; margin-bottom: 5px; padding: 12px 20px; color: rgba(255,255,255,0.7) !important; transition: 0.2s; }
        .nav-link:hover { background: rgba(255,255,255,0.1); color: #fff !important; }
        .nav-link.active { 
            background-color: #ffc107 !important; 
            color: #212529 !important; 
            font-weight: 600; 
            box-shadow: 0 4px 12px rgba(255,193,7,0.3); 
        }
        .nav-link.active i { color: #212529 !important; }

        .content-wrapper { width: 100%; }
        .sidebar-header h1 { font-size: 1.5rem; letter-spacing: 2px; }
    </style>
</head>
<body>
    <div class="d-flex">
        <nav class="sidebar bg-dark p-4 shadow-lg">
            <div class="sidebar-header mb-5">
                <div class="d-flex align-items-center mb-1">
                    <i class="bi bi-building-fill text-warning fs-2 me-3"></i>
                    <h1 class="fw-bold mb-0 text-white">DORMIFY</h1>
                </div>
                <div class="ps-5">
                    <p class="mb-0 text-warning small fw-bold">GROUP FLM</p>
                    <p class="text-muted mb-0" style="font-size: 0.75rem;">System Administrators</p>
                </div>
            </div>

            <ul class="nav nav-pills flex-column">
                <li class="nav-item">
                    <a href="/Dashboard/Index" class="nav-link @(currentPath.StartsWith("/Dashboard") || currentPath == "/Index" ? "active" : "")">
                        <i class="bi bi-grid-1x2-fill me-3"></i>Dashboard
                    </a>
                </li>

                <li class="nav-item">
                    <a href="/Students/Index" class="nav-link @(currentPath.StartsWith("/Students") ? "active" : "")">
                        <i class="bi bi-people-fill me-3"></i>Students
                    </a>
                </li>

                <li class="nav-item">
                    <a href="/Rooms/Index" class="nav-link @(currentPath.StartsWith("/Rooms") ? "active" : "")">
                        <i class="bi bi-door-open-fill me-3"></i>Rooms
                    </a>
                </li>

                <li class="nav-item">
                    <a href="/Registrations/Index" class="nav-link @(currentPath.StartsWith("/Registrations") ? "active" : "")">
                        <i class="bi bi-card-checklist me-3"></i>Registrations
                    </a>
                </li>

                <li class="nav-item">
                    <a href="/Payments/Index" class="nav-link @(currentPath.StartsWith("/Payments") ? "active" : "")">
                        <i class="bi bi-cash-stack me-3"></i>Payments
                    </a>
                </li>

                <li class="nav-item">
                    <a href="/Maintenance/Index" class="nav-link @(currentPath.StartsWith("/Maintenance") ? "active" : "")">
                        <i class="bi bi-tools me-3"></i>Maintenance
                    </a>
                </li>
                
                <hr class="text-secondary my-4">
                
                <li class="nav-item">
                    <a href="/Admin/Index" class="nav-link @(currentPath.StartsWith("/Admin") ? "active" : "")">
                        <i class="bi bi-person-badge-fill me-3"></i>Admin Settings
                    </a>
                </li>

                <li class="nav-item">
                    <form method="post" asp-page="/Login/Login" asp-page-handler="Logout">
                        <button type="submit" class="btn btn-danger">Logout</button>
                    </form>
                </li>
            </ul>
        </nav>
        <div class="content-wrapper">
            <header class="bg-white border-bottom p-3 d-flex justify-content-between align-items-center shadow-sm mb-4">
                <span class="text-muted fw-medium ms-3">Management System</span>
                <div class="d-flex align-items-center me-3">
                    <div class="text-end me-3 d-none d-md-block">
                        <p class="mb-0 fw-bold small">GROUP FLM</p>
                        <p class="mb-0 text-muted" style="font-size: 0.7rem;">System Administrator</p>
                    </div>
                    <div class="bg-warning rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 40px; height: 40px;">
                        <i class="bi bi-person-fill text-dark"></i>
                    </div>
                </div>
            </header>

            <main role="main" class="px-4 pb-5">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
@page
@model DormManagementSystem.Pages.Rooms.CreateModel
@{
    ViewData["Title"] = "Add Room";
}

<div class="container-fluid px-5 mt-5">
    <div class="card border-0 shadow-lg mx-auto" style="max-width: 500px; border-radius: 15px;">
        <div class="card-header bg-success text-white p-4" style="border-radius: 15px 15px 0 0;">
            <h5 class="fw-bold mb-0"><i class="bi bi-door-open-fill me-2"></i>Register New Room</h5>
        </div>
        <div class="card-body p-4 bg-white" style="border-radius: 0 0 15px 15px;">

            <div asp-validation-summary="All" class="text-danger small mb-3 fw-bold"></div>

            <form method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label small fw-bold">Room Number</label>
                    <input asp-for="Room.RoomNumber" class="form-control border-0 bg-light shadow-sm" placeholder="e.g., 101" required />
                </div>
                
                <div class="mb-3">
                    <label class="form-label small fw-bold">Max Capacity</label>
                    <input asp-for="Room.Capacity" class="form-control border-0 bg-light shadow-sm" type="number" min="1" required />
                </div>

                <div class="mb-4">
                    <label class="form-label small fw-bold">Room Status</label>
                    <select asp-for="Room.RoomStatus" class="form-select border-0 bg-light shadow-sm">
                        <option value="Available">Available</option>
                        <option value="Maintenance">Maintenance</option>
                        <option value="Full">Full</option>
                    </select>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-success fw-bold py-2 shadow-sm rounded-3">
                        Save to DormitoryDB
                    </button>
                    <a asp-page="./Index" class="btn btn-outline-secondary border-0 py-2">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}